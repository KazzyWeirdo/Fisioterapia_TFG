sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetAllPatientsController
  participant GetAllPatientsService
  participant PatientRepository

  Client->>JWTFilter: GET /patients/list?page=0&size=10 + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetAllPatientsController: forward request
    GetAllPatientsController->>GetAllPatientsService: getAllPatients(PageQuery{page, size})
    GetAllPatientsService->>GetAllPatientsService: validate(page >= 0, size > 0)
    alt Paràmetres invàlids
      GetAllPatientsService-->>GetAllPatientsController: throw InvalidPageQueryException
      GetAllPatientsController-->>Client: 400 Bad Request
    else Paràmetres vàlids
      GetAllPatientsService->>PatientRepository: findAllPaged(page, size)
      PatientRepository-->>GetAllPatientsService: PagedResponse[PatientSummaryElement]
      GetAllPatientsService-->>GetAllPatientsController: PagedResponse[PatientSummaryElement]
      alt Llista buida
        GetAllPatientsController-->>Client: 204 No Content
      else Llista amb dades
        GetAllPatientsController-->>Client: 200 OK {PagedResponse[PatientListWebModel]}
      end
    end
  end
