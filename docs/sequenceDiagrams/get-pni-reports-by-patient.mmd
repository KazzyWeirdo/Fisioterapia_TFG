sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetPniReportsFromPatientController
  participant GetPniReportsFromPatientService
  participant PatientRepository
  participant PniReportRepository

  Client->>JWTFilter: GET /pni/{patientId}?page=0&size=10 + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetPniReportsFromPatientController: forward request
    GetPniReportsFromPatientController->>GetPniReportsFromPatientService: getPniReportsFromPatient(patientId, PageQuery)
    GetPniReportsFromPatientService->>GetPniReportsFromPatientService: validate(page >= 0, size > 0)
    alt Paràmetres invàlids
      GetPniReportsFromPatientService-->>GetPniReportsFromPatientController: throw InvalidPageQueryException
      GetPniReportsFromPatientController-->>Client: 400 Bad Request
    else Paràmetres vàlids
      GetPniReportsFromPatientService->>PatientRepository: findById(patientId)
      alt Pacient no trobat
        PatientRepository-->>GetPniReportsFromPatientService: Optional.empty()
        GetPniReportsFromPatientService-->>GetPniReportsFromPatientController: throw InvalidIdException
        GetPniReportsFromPatientController-->>Client: 404 Not Found
      else Pacient trobat
        PatientRepository-->>GetPniReportsFromPatientService: Optional[patient]
        GetPniReportsFromPatientService->>PniReportRepository: findByPatientIdPaged(patientId, page, size)
        PniReportRepository-->>GetPniReportsFromPatientService: PagedResponse[PniReport]
        GetPniReportsFromPatientService-->>GetPniReportsFromPatientController: PagedResponse[PniReport]
        alt Llista buida
          GetPniReportsFromPatientController-->>Client: 204 No Content
        else Llista amb dades
          GetPniReportsFromPatientController-->>Client: 200 OK {PagedResponse[PniReportListWebModel]}
        end
      end
    end
  end
