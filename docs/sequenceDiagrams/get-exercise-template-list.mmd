sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetAllExerciseTemplatesController
  participant GetAllExerciseTemplatesService
  participant ExerciseTemplateRepository

  Client->>JWTFilter: GET /exercise-template + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetAllExerciseTemplatesController: forward request
    GetAllExerciseTemplatesController->>GetAllExerciseTemplatesService: getAllExerciseTemplates()
    GetAllExerciseTemplatesService->>ExerciseTemplateRepository: findAll()
    ExerciseTemplateRepository-->>GetAllExerciseTemplatesService: List[ExerciseTemplate]
    GetAllExerciseTemplatesService-->>GetAllExerciseTemplatesController: List[ExerciseTemplate]
    GetAllExerciseTemplatesController-->>Client: 200 OK {List[ExerciseTemplateWebModel]}
  end
