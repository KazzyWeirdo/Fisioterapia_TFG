sequenceDiagram
  actor Client
  participant JWTFilter
  participant CreateExerciseTemplateController
  participant CreateExerciseTemplateService
  participant ExerciseTemplateRepository

  Client->>JWTFilter: POST /exercise-template {ExerciseTemplateCreationModel} + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>CreateExerciseTemplateController: forward request
    CreateExerciseTemplateController->>CreateExerciseTemplateService: createExerciseTemplate(exerciseTemplate)
    CreateExerciseTemplateService->>ExerciseTemplateRepository: save(exerciseTemplate)
    ExerciseTemplateRepository-->>CreateExerciseTemplateService: saved
    CreateExerciseTemplateService-->>CreateExerciseTemplateController: void
    CreateExerciseTemplateController-->>Client: 200 OK
  end
