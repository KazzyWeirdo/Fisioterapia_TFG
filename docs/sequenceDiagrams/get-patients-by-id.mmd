sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetPatientController
  participant GetPatientService
  participant PatientRepository

  Client->>JWTFilter: GET /patients/{patientId} + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetPatientController: forward request
    GetPatientController->>GetPatientService: getPatient(patientId)
    GetPatientService->>PatientRepository: findById(patientId)
    alt Pacient no trobat
      PatientRepository-->>GetPatientService: Optional.empty()
      GetPatientService-->>GetPatientController: throw InvalidIdException
      GetPatientController-->>Client: 404 Not Found
    else Pacient trobat
      PatientRepository-->>GetPatientService: Optional[patient]
      GetPatientService-->>GetPatientController: patient
      GetPatientController-->>Client: 200 OK {PatientWebModel}
    end
  end
