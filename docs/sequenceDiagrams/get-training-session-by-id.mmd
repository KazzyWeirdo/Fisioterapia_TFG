sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetTrainingSessionController
  participant GetTrainingSessionService
  participant TrainingSessionRepository

  Client->>JWTFilter: GET /training-session/session/{sessionId} + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetTrainingSessionController: forward request
    GetTrainingSessionController->>GetTrainingSessionService: getTrainingSession(sessionId)
    GetTrainingSessionService->>TrainingSessionRepository: findById(sessionId)
    alt Sessió no trobada
      TrainingSessionRepository-->>GetTrainingSessionService: Optional.empty()
      GetTrainingSessionService-->>GetTrainingSessionController: throw InvalidIdException
      GetTrainingSessionController-->>Client: 404 Not Found
    else Sessió trobada
      TrainingSessionRepository-->>GetTrainingSessionService: Optional[trainingSession]
      GetTrainingSessionService-->>GetTrainingSessionController: trainingSession
      GetTrainingSessionController-->>Client: 200 OK {TrainingSessionWebModel}
    end
  end
