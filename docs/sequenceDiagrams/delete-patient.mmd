sequenceDiagram
  actor Client
  participant JWTFilter
  participant SecurityConfig
  participant DeletePatientController
  participant AuditLogAspect
  participant DeletePatientService
  participant PatientRepository
  participant IndibaSessionRepository
  participant PniReportRepository
  participant TrainingSessionRepository
  participant AuditLogRepository

  Client->>JWTFilter: DELETE /patients/{id} + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>SecurityConfig: checkScope(ADMIN)
    alt Rol no és ADMIN
      SecurityConfig-->>Client: 403 Forbidden
    else Rol és ADMIN
      SecurityConfig->>DeletePatientController: forward request {id}
      DeletePatientController->>DeletePatientService: delete(PatientId)
      DeletePatientService->>PatientRepository: findById(PatientId)
      alt Pacient no existeix
        PatientRepository-->>DeletePatientService: Optional.empty()
        DeletePatientService-->>DeletePatientController: throw InvalidIdException
        DeletePatientController-->>Client: 404 Not Found
      else Pacient existeix
        PatientRepository-->>DeletePatientService: Optional[patient]
        DeletePatientService->>IndibaSessionRepository: deleteAllByPatientId(PatientId)
        IndibaSessionRepository-->>DeletePatientService: void
        DeletePatientService->>PniReportRepository: deleteAllByPatientId(PatientId)
        PniReportRepository-->>DeletePatientService: void
        DeletePatientService->>TrainingSessionRepository: deleteAllByPatientId(PatientId)
        TrainingSessionRepository-->>DeletePatientService: void
        Note over AuditLogAspect: @Before — captura PatientId<br/>abans que s'esborri l'entitat
        DeletePatientService->>AuditLogAspect: [AOP intercept] deleteById(PatientId)
        AuditLogAspect->>AuditLogAspect: buildAuditLog("Patient", "DELETE", user, "PatientId: {id}")
        AuditLogAspect->>AuditLogRepository: save(auditLog)
        Note over AuditLogRepository: Persistit a MongoDB
        AuditLogRepository-->>AuditLogAspect: saved
        AuditLogAspect->>PatientRepository: deleteById(PatientId) [proceed()]
        PatientRepository-->>AuditLogAspect: void
        AuditLogAspect-->>DeletePatientService: void (transparent)
        DeletePatientService-->>DeletePatientController: void
        DeletePatientController-->>Client: 204 No Content
      end
    end
  end
