sequenceDiagram
  actor Client
  participant JWTFilter
  participant UpdatePatientFunctionalScoreController
  participant UpdatePatientFunctionalScoreService
  participant PatientRepository

  Client->>JWTFilter: PATCH /patients/{id}/functional-score {score} + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>UpdatePatientFunctionalScoreController: forward request {id, score}
    UpdatePatientFunctionalScoreController->>UpdatePatientFunctionalScoreController: @Valid score (0-100)
    alt Score fora de rang
      UpdatePatientFunctionalScoreController-->>Client: 400 Bad Request
    else Score vàlid
      UpdatePatientFunctionalScoreController->>UpdatePatientFunctionalScoreService: updateFunctionalScore(PatientId, score)
      UpdatePatientFunctionalScoreService->>PatientRepository: findById(PatientId)
      alt Pacient no existeix
        PatientRepository-->>UpdatePatientFunctionalScoreService: Optional.empty()
        UpdatePatientFunctionalScoreService-->>UpdatePatientFunctionalScoreController: throw InvalidIdException
        UpdatePatientFunctionalScoreController-->>Client: 404 Not Found
      else Pacient existeix
        PatientRepository-->>UpdatePatientFunctionalScoreService: Optional[patient]
        UpdatePatientFunctionalScoreService->>UpdatePatientFunctionalScoreService: patient.applyFunctionalScore(score)
        UpdatePatientFunctionalScoreService->>PatientRepository: save(patient)
        PatientRepository-->>UpdatePatientFunctionalScoreService: saved
        UpdatePatientFunctionalScoreService-->>UpdatePatientFunctionalScoreController: void
        UpdatePatientFunctionalScoreController-->>Client: 200 OK
      end
    end
  end
