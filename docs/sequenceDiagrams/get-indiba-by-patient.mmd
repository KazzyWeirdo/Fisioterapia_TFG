sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetIndibaSessionFromPatientController
  participant GetIndibaSessionFromPatientService
  participant PatientRepository
  participant IndibaSessionRepository

  Client->>JWTFilter: GET /indiba/{patientId}?page=0&size=10 + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetIndibaSessionFromPatientController: forward request
    GetIndibaSessionFromPatientController->>GetIndibaSessionFromPatientService: getIndibaSessionsFromPatient(patientId, PageQuery)
    GetIndibaSessionFromPatientService->>GetIndibaSessionFromPatientService: validate(page >= 0, size > 0)
    alt Paràmetres invàlids
      GetIndibaSessionFromPatientService-->>GetIndibaSessionFromPatientController: throw InvalidPageQueryException
      GetIndibaSessionFromPatientController-->>Client: 400 Bad Request
    else Paràmetres vàlids
      GetIndibaSessionFromPatientService->>PatientRepository: findById(patientId)
      alt Pacient no trobat
        PatientRepository-->>GetIndibaSessionFromPatientService: Optional.empty()
        GetIndibaSessionFromPatientService-->>GetIndibaSessionFromPatientController: throw InvalidIdException
        GetIndibaSessionFromPatientController-->>Client: 404 Not Found
      else Pacient trobat
        PatientRepository-->>GetIndibaSessionFromPatientService: Optional[patient]
        GetIndibaSessionFromPatientService->>IndibaSessionRepository: findByPatientIdPaged(patientId, page, size)
        IndibaSessionRepository-->>GetIndibaSessionFromPatientService: PagedResponse[IndibaSession]
        GetIndibaSessionFromPatientService-->>GetIndibaSessionFromPatientController: PagedResponse[IndibaSession]
        alt Llista buida
          GetIndibaSessionFromPatientController-->>Client: 204 No Content
        else Llista amb dades
          GetIndibaSessionFromPatientController-->>Client: 200 OK {PagedResponse[IndibaListWebModel]}
        end
      end
    end
  end
