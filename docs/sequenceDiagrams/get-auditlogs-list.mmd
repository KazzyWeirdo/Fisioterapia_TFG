sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetAllAuditLogsController
  participant GetAllAuditLogsService
  participant AuditLogRepository

  Client->>JWTFilter: GET /auditlogs/list?page=0&size=10 + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetAllAuditLogsController: forward request
    GetAllAuditLogsController->>GetAllAuditLogsService: getAllAuditLogs(PageQuery{page, size})
    GetAllAuditLogsService->>GetAllAuditLogsService: validate(page >= 0, size > 0)
    alt Paràmetres invàlids
      GetAllAuditLogsService-->>GetAllAuditLogsController: throw InvalidPageQueryException
      GetAllAuditLogsController-->>Client: 400 Bad Request
    else Paràmetres vàlids
      GetAllAuditLogsService->>AuditLogRepository: findAllPaged(page, size)
      AuditLogRepository-->>GetAllAuditLogsService: PagedResponse[AuditLog]
      GetAllAuditLogsService-->>GetAllAuditLogsController: PagedResponse[AuditLog]
      alt Llista buida
        GetAllAuditLogsController-->>Client: 204 No Content
      else Llista amb dades
        GetAllAuditLogsController-->>Client: 200 OK {PagedResponse[AuditLogListWebModel]}
      end
    end
  end
