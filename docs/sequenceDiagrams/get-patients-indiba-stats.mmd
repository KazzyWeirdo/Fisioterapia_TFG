sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetIndibaSessionStatsController
  participant GetIndibaSessionStatsService
  participant IndibaSessionRepository

  Client->>JWTFilter: GET /patients/{id}/indiba-stats + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetIndibaSessionStatsController: forward request {id}
    GetIndibaSessionStatsController->>GetIndibaSessionStatsService: getIndibaSessionStats(PatientId)
    GetIndibaSessionStatsService->>IndibaSessionRepository: findAllByPatientId(PatientId)
    IndibaSessionRepository-->>GetIndibaSessionStatsService: List[IndibaSession]
    alt Sense sessions
      GetIndibaSessionStatsService-->>GetIndibaSessionStatsController: IndibaSessionStats(0, 0, null, null, null, {})
    else Amb sessions
      GetIndibaSessionStatsService->>GetIndibaSessionStatsService: calcular avgDurationMinutes
      GetIndibaSessionStatsService->>GetIndibaSessionStatsService: calcular mostTreatedArea
      GetIndibaSessionStatsService->>GetIndibaSessionStatsService: calcular avgCapacitiveIntensity
      GetIndibaSessionStatsService->>GetIndibaSessionStatsService: calcular avgResistiveIntensity
      GetIndibaSessionStatsService->>GetIndibaSessionStatsService: calcular modeDistribution
      GetIndibaSessionStatsService-->>GetIndibaSessionStatsController: IndibaSessionStats(total, avg, area, cap, res, modes)
    end
    GetIndibaSessionStatsController-->>Client: 200 OK {IndibaSessionStatsWebModel}
  end
