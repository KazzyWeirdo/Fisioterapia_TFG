sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetIndibaSessionController
  participant GetIndibaSessionService
  participant IndibaSessionRepository

  Client->>JWTFilter: GET /indiba/session/{sessionId} + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetIndibaSessionController: forward request
    GetIndibaSessionController->>GetIndibaSessionService: getIndibaSession(sessionId)
    GetIndibaSessionService->>IndibaSessionRepository: findById(sessionId)
    alt Sessió no trobada
      IndibaSessionRepository-->>GetIndibaSessionService: Optional.empty()
      GetIndibaSessionService-->>GetIndibaSessionController: throw InvalidIdException
      GetIndibaSessionController-->>Client: 404 Not Found
    else Sessió trobada
      IndibaSessionRepository-->>GetIndibaSessionService: Optional[indibaSession]
      GetIndibaSessionService-->>GetIndibaSessionController: indibaSession
      GetIndibaSessionController-->>Client: 200 OK {IndibaWebModel}
    end
  end
