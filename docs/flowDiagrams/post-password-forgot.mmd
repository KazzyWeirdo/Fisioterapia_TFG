sequenceDiagram
  actor Client
  participant PasswordResetController
  participant RequestPasswordResetService
  participant PhysiotherapistRepository
  participant PasswordResetTokenRepository
  participant EmailSenderPort

  Client->>PasswordResetController: POST /password/forgot {email}
  PasswordResetController->>RequestPasswordResetService: requestReset(email)
  RequestPasswordResetService->>PhysiotherapistRepository: findByEmail(email)
  alt Fisioterapeuta no trobat
    PhysiotherapistRepository-->>RequestPasswordResetService: Optional.empty()
    RequestPasswordResetService-->>PasswordResetController: throw InvalidEmailException
    PasswordResetController-->>Client: 404 Not Found
  else Fisioterapeuta trobat
    PhysiotherapistRepository-->>RequestPasswordResetService: Optional[physiotherapist]
    RequestPasswordResetService->>PasswordResetTokenRepository: save(token, physiotherapist, expiresAt +1h)
    PasswordResetTokenRepository-->>RequestPasswordResetService: saved
    RequestPasswordResetService->>EmailSenderPort: sendResetEmail(email, resetLink)
    EmailSenderPort-->>RequestPasswordResetService: sent
    RequestPasswordResetService-->>PasswordResetController: void
    PasswordResetController-->>Client: 200 OK
  end
