sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetPatientTransitionRatioController
  participant GetPatientTransitionRatioService
  participant PatientRepository
  participant IndibaSessionRepository
  participant TrainingSessionRepository

  Client->>JWTFilter: GET /statistics/{patientId}/{year}/patient-transition-ratio + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetPatientTransitionRatioController: forward request
    GetPatientTransitionRatioController->>GetPatientTransitionRatioService: getTransitionRatio(patientId, year)
    GetPatientTransitionRatioService->>PatientRepository: findById(patientId)
    alt Pacient no trobat
      PatientRepository-->>GetPatientTransitionRatioService: Optional.empty()
      GetPatientTransitionRatioService-->>GetPatientTransitionRatioController: throw InvalidIdException
      GetPatientTransitionRatioController-->>Client: 404 Not Found
    else Pacient trobat
      PatientRepository-->>GetPatientTransitionRatioService: Optional[patient]
      loop Per cada mes (1-12, fins al mes actual si any actual)
        GetPatientTransitionRatioService->>IndibaSessionRepository: countByPatientAndMonth(patientId, year, month)
        IndibaSessionRepository-->>GetPatientTransitionRatioService: indibaCount
        GetPatientTransitionRatioService->>TrainingSessionRepository: countByPatientAndMonth(patientId, year, month)
        TrainingSessionRepository-->>GetPatientTransitionRatioService: trainingCount
      end
      GetPatientTransitionRatioService-->>GetPatientTransitionRatioController: List[PatientMonthTransitionRatio]
      alt Llista buida
        GetPatientTransitionRatioController-->>Client: 204 No Content
      else Llista amb dades
        GetPatientTransitionRatioController-->>Client: 200 OK {List[TransitionRatioWebModel]}
      end
    end
  end
