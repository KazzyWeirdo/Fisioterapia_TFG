sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetWorkloadProgressionController
  participant GetWorkloadProgressionService
  participant PatientRepository
  participant TrainingSessionRepository

  Client->>JWTFilter: GET /statistics/{patientId}/{exerciseName}/workload-progression + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetWorkloadProgressionController: forward request
    GetWorkloadProgressionController->>GetWorkloadProgressionService: calculateProgression(patientId, exerciseName)
    GetWorkloadProgressionService->>PatientRepository: findById(patientId)
    alt Pacient no trobat
      PatientRepository-->>GetWorkloadProgressionService: Optional.empty()
      GetWorkloadProgressionService-->>GetWorkloadProgressionController: throw InvalidIdException
      GetWorkloadProgressionController-->>Client: 404 Not Found
    else Pacient trobat
      PatientRepository-->>GetWorkloadProgressionService: Optional[patient]
      GetWorkloadProgressionService->>TrainingSessionRepository: findWorkloadByPatientAndExercise(patientId, exerciseName)
      Note over TrainingSessionRepository: Calcula volum = sets × reps × weightKg per data
      TrainingSessionRepository-->>GetWorkloadProgressionService: List[WorkloadProgression{date, workload}]
      GetWorkloadProgressionService-->>GetWorkloadProgressionController: List[WorkloadProgression]
      alt Llista buida
        GetWorkloadProgressionController-->>Client: 204 No Content
      else Llista amb dades
        GetWorkloadProgressionController-->>Client: 200 OK {List[WorkloadProgression]}
      end
    end
  end
