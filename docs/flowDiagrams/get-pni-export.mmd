sequenceDiagram
  actor Client
  participant JWTFilter
  participant GetAllPniReportsForExportController
  participant GetAllPniReportsForExportService
  participant PniReportRepository

  Client->>JWTFilter: GET /pni/export + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>GetAllPniReportsForExportController: forward request
    GetAllPniReportsForExportController->>GetAllPniReportsForExportService: getAllPniReportsForExport()
    GetAllPniReportsForExportService->>PniReportRepository: findAll()
    PniReportRepository-->>GetAllPniReportsForExportService: List[PniReport]
    GetAllPniReportsForExportService-->>GetAllPniReportsForExportController: List[PniReport]
    GetAllPniReportsForExportController-->>Client: 200 OK {List[PniExportWebModel]}
  end
