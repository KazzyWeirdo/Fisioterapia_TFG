sequenceDiagram
  actor Client
  participant PasswordResetController
  participant ResetPasswordService
  participant PasswordResetTokenRepository
  participant PhysiotherapistRepository
  participant PasswordEncoderPort

  Client->>PasswordResetController: POST /password/reset {token, newPassword}
  PasswordResetController->>ResetPasswordService: reset(token, newPassword)
  ResetPasswordService->>PasswordResetTokenRepository: findByToken(token)
  alt Token no trobat
    PasswordResetTokenRepository-->>ResetPasswordService: Optional.empty()
    ResetPasswordService-->>PasswordResetController: throw InvalidTokenException
    PasswordResetController-->>Client: 400 Bad Request
  else Token trobat
    PasswordResetTokenRepository-->>ResetPasswordService: Optional[passwordResetToken]
    ResetPasswordService->>ResetPasswordService: isExpired(expiresAt)
    alt Token expirat
      ResetPasswordService-->>PasswordResetController: throw ExpiredTokenException
      PasswordResetController-->>Client: 400 Bad Request
    else Token vàlid
      ResetPasswordService->>PasswordEncoderPort: encode(newPassword)
      PasswordEncoderPort-->>ResetPasswordService: encodedPassword
      ResetPasswordService->>PhysiotherapistRepository: updatePassword(physiotherapistId, encodedPassword)
      PhysiotherapistRepository-->>ResetPasswordService: updated
      ResetPasswordService->>PasswordResetTokenRepository: delete(token)
      PasswordResetTokenRepository-->>ResetPasswordService: deleted
      ResetPasswordService-->>PasswordResetController: void
      PasswordResetController-->>Client: 200 OK
    end
  end
