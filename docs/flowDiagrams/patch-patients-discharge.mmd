sequenceDiagram
  actor Client
  participant JWTFilter
  participant DischargePatientController
  participant DischargePatientService
  participant PatientRepository

  Client->>JWTFilter: PATCH /patients/{id}/discharge + Bearer token
  JWTFilter->>JWTFilter: validateToken()
  alt Token invàlid
    JWTFilter-->>Client: 401 Unauthorized
  else Token vàlid
    JWTFilter->>DischargePatientController: forward request {id}
    DischargePatientController->>DischargePatientService: discharge(PatientId)
    DischargePatientService->>PatientRepository: findById(PatientId)
    alt Pacient no existeix
      PatientRepository-->>DischargePatientService: Optional.empty()
      DischargePatientService-->>DischargePatientController: throw InvalidIdException
      DischargePatientController-->>Client: 404 Not Found
    else Pacient existeix
      PatientRepository-->>DischargePatientService: Optional[patient]
      DischargePatientService->>DischargePatientService: patient.discharge(LocalDate.now())
      Note over DischargePatientService: Idempotent — si ja té dischargeDate, no canvia
      DischargePatientService->>PatientRepository: save(patient)
      PatientRepository-->>DischargePatientService: saved
      DischargePatientService-->>DischargePatientController: void
      DischargePatientController-->>Client: 200 OK
    end
  end
